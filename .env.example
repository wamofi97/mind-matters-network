# --- Sanity CMS ---
# Find these in https://www.sanity.io/manage after creating a project.
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"

# Write token (Editor/Deploy permissions) — OPTIONAL. The running site only reads
# from Sanity; this is only needed if you add a script that writes to Sanity.
# Never expose this in the browser. Create at: Sanity manage > API > Tokens.
SANITY_API_WRITE_TOKEN="your_write_token"

# Shared secret for on-demand revalidation. Use any long random string, and set
# the SAME value as the "Secret" on the Sanity webhook (see CMS.md). This lets the
# site refresh instantly when content is published instead of after ~60s.
SANITY_REVALIDATE_SECRET="your_random_secret"
